# Local dev: copiez ces valeurs depuis Backend/.env, ou laissez Vite les charger via envDir (vite.config.ts).
# Vercel: définissez ces variables dans Project Settings → Environment Variables.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_API_URL=https://toliarevent.onrender.com/api/auth

# Backend (partagé via envDir) — URL publique du frontend pour les e-mails de confirmation
FRONTEND_URL=http://localhost:5173
